{
  "permissions": {
    "allow": [
      "Glob(*)",
      "Grep(*)",
      "List(*)",
      "Read(**)",
      "Read(/tmp/*)",
      "WebSearch(*)",
      "Bash(basename:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(export:*)",
      "Bash(file:*)",
      "Bash(git:*)",
      "Bash(od:*)",
      "Bash(open:*)",
      "Bash(printf:*)",
      "Bash(sort:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:aws.amazon.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:dev.classmethod.jp)",
      "WebFetch(domain:developer.hashicorp.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.localstack.cloud)",
      "WebFetch(domain:docs.opensearch.org)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.typescriptlang.org)",
      "Edit(/tmp/*)",
      "Write(/tmp/*)",
      "mcp__plugin_context7_context7"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(chmod -R:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout .:*)",
      "Bash(git clean -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(docker push:*)",
      "Bash(git push:*)",
      "Bash(cdk deploy:*)",
      "Bash(kubectl apply:*)",
      "Bash(terraform apply:*)",
      "Bash(cdk destroy:*)",
      "Bash(kubectl delete:*)",
      "Bash(terraform destroy:*)",
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/genai/scripts/pre-commit-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/genai/scripts/post-edit-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/genai/scripts/stop-notify.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/genai/scripts/config-change-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "zsh ~/dotfiles/genai/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "outputStyle": "explanatory",
  "language": "Japanese",
  "sandbox": {
    "enabled": false,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    },
    "filesystem": {
      "allowWrite": ["/tmp"],
      "denyWrite": ["~/.bashrc", "~/.zshrc", "~/.ssh"],
      "denyRead": [
        "./.env",
        "./secrets",
        "./config/credentials.json",
        "./build",
        "~/.ssh",
        "~/.aws/credentials"
      ]
    },
    "excludedCommands": ["open"]
  }
}
