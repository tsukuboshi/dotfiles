{
  "permissions": {
    "allow": [
      "Glob(*)",
      "List(*)",
      "Read(**)",
      "Bash(cat:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(open:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(xxd:*)"
    ],
    "deny": []
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/llm/scripts/statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/llm/scripts/edit-hook.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  }
}
