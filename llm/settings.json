{
  "permissions": {
    "allow": [
      "Glob(*)",
      "List(*)",
      "Read(**)",
      "Bash(cat:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(open:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(xxd:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/llm/scripts/pre-commit-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/llm/scripts/post-edit-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/llm/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "Japanese"
}
